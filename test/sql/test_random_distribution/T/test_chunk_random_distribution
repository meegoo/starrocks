-- name: test_chunk_random_distribution_compression @sequential
-- Test that chunk-level random distribution keeps consecutive auto_increment
-- values together within each tablet, resulting in better compression.
-- Compare: random with 10 buckets vs random with 1 bucket (baseline).
-- With 1 bucket all rows go to the same tablet, so IDs are perfectly sequential.
-- With chunk-level distribution on 10 buckets, each chunk of rows stays together,
-- so compression should be close to the 1-bucket baseline.

create database test_chunk_random_dist_${uuid0};
use test_chunk_random_dist_${uuid0};

-- Random distribution with 10 buckets
CREATE TABLE t_random_10 (
    id BIGINT NOT NULL AUTO_INCREMENT,
    v1 BIGINT NOT NULL
)
DUPLICATE KEY(id)
DISTRIBUTED BY RANDOM BUCKETS 10
PROPERTIES (
    "replication_num" = "1",
    "compression" = "LZ4"
);

-- Random distribution with 1 bucket (baseline: all rows in one tablet)
CREATE TABLE t_random_1 (
    id BIGINT NOT NULL AUTO_INCREMENT,
    v1 BIGINT NOT NULL
)
DUPLICATE KEY(id)
DISTRIBUTED BY RANDOM BUCKETS 1
PROPERTIES (
    "replication_num" = "1",
    "compression" = "LZ4"
);

-- Insert strictly increasing data (100k rows) into both tables
INSERT INTO t_random_10(v1) SELECT generate_series FROM TABLE(generate_series(1, 100000));
INSERT INTO t_random_1(v1) SELECT generate_series FROM TABLE(generate_series(1, 100000));

-- Verify row counts
SELECT count(*) FROM t_random_10;
SELECT count(*) FROM t_random_1;

-- Wait for data to be flushed
SELECT sleep(2);

-- Query total data size for the 10-bucket table
[UC]size_10=SELECT SUM(DATA_SIZE) FROM information_schema.be_tablets t, information_schema.tables_config c WHERE t.TABLE_ID = c.TABLE_ID AND c.TABLE_NAME = 't_random_10' AND c.TABLE_SCHEMA = 'test_chunk_random_dist_${uuid0}';

-- Query total data size for the 1-bucket table (baseline)
[UC]size_1=SELECT SUM(DATA_SIZE) FROM information_schema.be_tablets t, information_schema.tables_config c WHERE t.TABLE_ID = c.TABLE_ID AND c.TABLE_NAME = 't_random_1' AND c.TABLE_SCHEMA = 'test_chunk_random_dist_${uuid0}';

-- With chunk-level random distribution, the 10-bucket table should have
-- comparable data size to the 1-bucket baseline because consecutive IDs
-- stay together within each tablet, enabling good compression.
-- Before the fix (per-row round-robin), the ratio would be much worse.
SELECT ${size_10} <= ${size_1} * 1.1 AS compression_ratio_acceptable;

drop database test_chunk_random_dist_${uuid0} force;
